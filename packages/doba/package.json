{
  "name": "dobajs",
  "version": "0.0.4",
  "description": "Versioned data codec with Standard Schema support",
  "keywords": [
    "arktype",
    "codec",
    "migration",
    "schema",
    "standard-schema",
    "typescript",
    "valibot",
    "versioning",
    "zod"
  ],
  "homepage": "https://doba.karolbroda.com",
  "license": "MIT",
  "author": "Karol Broda <me@karolbroda.com> (https://karolbroda.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/karol-broda/doba",
    "directory": "packages/doba"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./result": {
      "types": "./dist/result.d.mts",
      "import": "./dist/result.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:types": "vitest --typecheck.only --run",
    "bench": "bun tests/registry.bench.ts",
    "bench:features": "bun tests/features.bench.ts",
    "bench:stress": "bun tests/stress.bench.ts",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "lint": "oxlint",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "check:publint": "publint",
    "check:attw": "attw --pack . --ignore-rules no-resolution cjs-resolves-to-esm",
    "prepublishOnly": "bun run build && bun run check:publint && bun run check:attw",
    "release": "bumpp"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.17.4",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "2.1.9",
    "bumpp": "11.0.1",
    "mitata": "1.0.34",
    "publint": "0.3.18",
    "tsdown": "0.18.4",
    "tsnapi": "0.3.2",
    "typescript": "catalog:",
    "vitest": "2.1.9"
  }
}
